# ─── AI Provider API Keys ────────────────────────────────────────
# Set the key for your chosen provider (LINAI_AI_PROVIDER in user config)

OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Ollama (local) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── LinAI Settings ──────────────────────────────────────────────
# Override config without editing config/user.json

LINAI_AI_PROVIDER=openai          # openai | gemini | ollama | anthropic
LINAI_AI_MODEL=gpt-4o
LINAI_DRY_RUN=false               # true to simulate all commands by default
LOG_LEVEL=warn                    # error | warn | info | debug
